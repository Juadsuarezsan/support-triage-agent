ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5

# Fine-tuned classifier model on HuggingFace Hub (publish your own)
CLASSIFIER_MODEL=Juadsuarezsan/distilbert-support-intent-lora
USE_LOCAL_CLASSIFIER=true   # falls back to zero-shot Claude if false

DATABASE_URL=postgresql://support:support_dev@localhost:5432/support
QDRANT_URL=http://localhost:6333

# Confidence thresholds for triage decisions
AUTO_RESOLVE_THRESHOLD=0.85
ESCALATE_THRESHOLD=0.60
